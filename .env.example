# ── Neo4j connection ────────────────────────────────────────────────────────────
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# ── llama.cpp server auto-management ───────────────────────────────────────────
# Set AUTO_START_SERVERS=true to have the app launch both llama.cpp servers
# automatically on chat start and shut them down on chat end.
# Leave false if you prefer to start them manually.
AUTO_START_SERVERS=true

# Path to the llama-server.exe binary (required when AUTO_START_SERVERS=true)
LLAMA_SERVER_EXE=C:\llama-cpp\llama-server.exe

# Embedding model path and server settings
EMBED_MODEL_PATH=C:\llama-cpp\models\bge-m3-Q8_0.gguf
EMBED_SERVER_PORT=8091
EMBED_N_CTX=8192

# LLM model path and server settings
LLM_MODEL_PATH=C:\llama-cpp\models\Qwen3.5-4B-Q8_0.gguf
LLM_SERVER_PORT=8092
LLM_N_CTX=4096

# How long to wait for each server to become healthy (seconds)
LLAMA_HEALTH_TIMEOUT=120

# These derived URLs are still used by the HTTP clients — keep them matching the ports above
EMBED_SERVER_URL=http://127.0.0.1:8091
LLM_SERVER_URL=http://127.0.0.1:8092

# ── Document scope (optional) ───────────────────────────────────────────────────
# Set to the source_sha256 value from document.json to scope all queries to one
# document. Leave blank to query across all documents in the graph.
# DOCUMENT_ID=

# ── Retrieval tuning (optional) ─────────────────────────────────────────────────
# VECTOR_TOP_K=8
# KEYWORD_TOP_K=8
# GRAPH_EXPANSION_LIMIT=5
# FINAL_EVIDENCE_LIMIT=10
# SEMANTIC_SIMILARITY_THRESHOLD=0.50

# ── LLM tuning (optional) ───────────────────────────────────────────────────────
# LLM_MAX_TOKENS=1024
# LLM_TEMPERATURE=0.0

# ── Misc (optional) ─────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# CREATE_FULLTEXT_INDEX=false
